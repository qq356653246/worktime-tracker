<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:titleTextColor="@android:color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 启用自动打卡 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_auto_check"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="开启后点击打卡按钮自动完成公司打卡"
                            android:textSize="12sp"
                            android:textColor="#666666"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/enableAutoCheckSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 公司打卡 App 包名 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/targetAppPackageLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_app_package"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:id="@+id/targetAppPackageValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="com.alibaba.android.rimet"
                            android:textSize="12sp"
                            android:textColor="#2196F3"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_app_hint"
                            android:textSize="11sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_more"
                        android:contentDescription="编辑"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 打卡按钮文字 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/checkButtonTextLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/check_button_text"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>

                        <TextView
                            android:id="@+id/checkButtonTextValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="上班打卡，下班打卡，打卡"
                            android:textSize="12sp"
                            android:textColor="#2196F3"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/check_button_hint"
                            android:textSize="11sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_more"
                        android:contentDescription="编辑"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 使用说明：\n\n1. 开启「启用自动打卡」开关\n2. 在弹出的对话框中点击「去开启」\n3. 找到「自动打卡服务」并开启\n4. 设置公司打卡 App 的包名\n5. 设置打卡按钮文字\n\n常见打卡软件包名：\n• 钉钉：com.alibaba.android.rimet\n• 企业微信：com.tencent.wework\n• 飞书：com.ss.android.lark"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"
                android:background="#F5F5F5"
                android:padding="12dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
